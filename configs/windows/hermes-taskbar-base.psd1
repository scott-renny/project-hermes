@{
    # Project Hermes initial taskbar baseline.
    # The layout favors a clean operations workspace while retaining
    # Task View and clock seconds for daily technical work.

    Alignment   = 'Center'
    Search      = 'Icon'
    TaskView    = 'Enabled'
    Widgets     = 'Disabled'
    AutoHide    = 'Disabled'
    ShowSeconds = 'Enabled'
}
