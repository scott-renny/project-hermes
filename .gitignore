# Generated logs and workstation inventory
logs/*
exports/*
!logs/.gitkeep
!exports/.gitkeep

# Local state and temporary files
*.tmp
*.bak
*.log
*.out.txt
*.err.txt

# PowerShell and editor artifacts
.vscode/
.history/
*.ps1xml

# Windows files
Thumbs.db
Desktop.ini

# Secrets and credentials
*.key
*.pem
*.pfx
*.p12
.env
.env.*
credentials*
secrets*

# Temporary backup files
*.bak
*.tmp
*.old
*~

# Generated Hermes runtime data
logs/*
exports/backups/*
exports/baseline/*
exports/state/*
exports/summaries/*

# Preserve folder structure
!logs/.gitkeep
!exports/backups/.gitkeep
!exports/baseline/.gitkeep
!exports/state/.gitkeep
!exports/summaries/.gitkeep

# Dated module backup folders
modules/**/*.backup-*
modules/**/*backup-*